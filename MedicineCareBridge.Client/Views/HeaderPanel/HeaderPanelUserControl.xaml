<UserControl x:Class="MedicineCareBridge.Client.Views.HeaderPanel.HeaderPanelUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MedicineCareBridge.Client.Views.HeaderPanel"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="800">


    <Border Background="#1976D2" Padding="20,10" CornerRadius="3">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Заголовок слева -->
            <TextBlock Text="Панель администратора"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Grid.Column="0" />

            <!-- Аватар + имя справа -->
            <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Grid.Column="1">
                <Grid Width="40" Height="40" Margin="0,0,10,0">
                    <Ellipse Fill="#4CAF50" />
                    <TextBlock Text="ИС"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Grid>

                <TextBlock Text="Иван Сергеевич"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="White"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
